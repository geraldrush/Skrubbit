{
  "name": "skrubbit",
  "version": "0.1.0",
  "private": true,
  "description": "Skrubb-it Products — cleaning & personal care e-commerce (Next.js + shadcn/ui on Cloudflare Workers)",
  "scripts": {
    "dev": "next dev",
    "build": "opennextjs-cloudflare build",
    "build:next": "next build",
